<Window
    x:Class="WpfPaint.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WPF Paint"
    WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Canvas 
            x:Name="DrawCanvas"
            Grid.Row="1"
            Background="White"
            MouseDown="DrawCanvas_MouseDown"
            MouseMove="DrawCanvas_MouseMove"
            MouseUp="DrawCanvas_MouseUp"/>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Height="60" Background="LightGray" VerticalAlignment="Top">

            <Button Width="40" Height="40" Background="Black" Click="ColorBlack_Click" Margin="5"/>
            <Button Width="40" Height="40" Background="Red" Click="ColorRed_Click" Margin="5"/>
            <Button Width="40" Height="40" Background="Blue" Click="ColorBlue_Click" Margin="5"/>
            <Button Width="40" Height="40" Background="Green" Click="ColorGreen_Click" Margin="5"/>
            <Button Width="40" Height="40" Background="Yellow" Click="ColorYellow_Click" Margin="5"/>
            <Button Width="40" Height="40" Background="Purple" Click="ColorPurple_Click" Margin="5"/>


            <Separator Width="2" Background="Gray" Margin="5"/>

            <Button Content="✏️" Width="40" Height="40" Click="PenTool_Click" FontSize="20" Margin="5"/>
            <Button Content="🧽" Width="40" Height="40" Click="EraserTool_Click" FontSize="20" Margin="5"/>
            <Button Content="▭" Width="40" Height="40" Click="RectangleTool_Click" FontSize="20" Margin="5"/>
            <Button Content="⭕" Width="40" Height="40" Click="EllipseTool_Click" FontSize="20" Margin="5"/>
            <Button Content="Text" Width="40" Height="40" Click="TextTool_Click" FontSize="12" Margin="5"/>

            <Separator Width="2" Background="Gray" Margin="5"/>


            <TextBlock Text="Kalınlık:" VerticalAlignment="Center" FontWeight="Bold" Margin="10,0,5,0"/>
            <Slider x:Name="ThicknessSlider"
            Width="150"
            Minimum="1"
            Maximum="20"
            Value="2"
            TickFrequency="1"
            IsSnapToTickEnabled="True"
            VerticalAlignment="Center"
            Margin="5"
            ValueChanged="ThicknessSlider_ValueChanged"/>
            <TextBlock x:Name="ThicknessLabel" 
               Text="2 px"
               VerticalAlignment="Center" 
               FontWeight="Bold"
               MinWidth="40"
               Margin="5"/>


            <Separator Width="2" Background="Gray" Margin="5"/>


            <Button Content="⮌" Width="40" Height="40" Click="Undo_Click" FontSize="20" Margin="5"/>
            <Button Content="⮎" Width="40" Height="40" Click="Redo_Click" FontSize="20" Margin="5"/>
            <Button Content="💾" Width="40" Height="40" Click="Save_Click" FontSize="20" Background="LightGreen" Margin="5"/>
        </StackPanel>
    </Grid>


</Window>
